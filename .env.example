# ──────────────────────────────────────────────────────────────────────
# WebGuard — example environment file
# Copy to `.env` and adjust values before running `docker compose up`.
# ──────────────────────────────────────────────────────────────────────

# Application
ENVIRONMENT=development
DEBUG=true

# JWT (used from Étape 2)
SECRET_KEY=replace-me-with-a-secure-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL
POSTGRES_USER=webguard
POSTGRES_PASSWORD=changeme
POSTGRES_DB=webguard
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis (used from Étape 4)
REDIS_URL=redis://redis:6379/0

# CORS — origines autorisées (séparées par des virgules)
BACKEND_CORS_ORIGINS=http://localhost:5173

# Frontend
VITE_API_BASE_URL=http://localhost:8000
